# PVE ceph repository provided by proxmox.com,
# https://pve.proxmox.com/wiki/Package_Repositories#sysadmin_package_repositories_ceph

{% if proxmox_pve_enable_ceph_repository %}
deb [signed-by={{ proxmox_pve_repository_keyring }}] http://download.proxmox.com/debian/ceph-{{ proxmox_pve_enable_ceph_repository_release }} {{ ansible_facts["distribution_release"] }} {{ proxmox_pve_enable_ceph_repository_version }}
{% else %}
#deb [signed-by={{ proxmox_pve_repository_keyring }}] http://download.proxmox.com/debian/ceph-{{ proxmox_pve_enable_ceph_repository_release }} {{ ansible_facts["distribution_release"] }} {{ proxmox_pve_enable_ceph_repository_version }}
{% endif %}
